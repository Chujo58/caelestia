{
    "toggles": {
        "music": {
            "spotify": {
                "enable": false
            },
            "feishin": {
                "enable": true,
                "match": [{ "class": "feishin" }],
                "move": true,
                "command": ["/home/chujo/Applications/Feishin-linux-x86_64.AppImage"]
            },
            "soundcloud": {
                "enable": true,
                "match": [{"class": "chrome-soundcloud.com__-Default"}],
                "move": true
            }
        },
        "google": {
            "routine": {
                "enable": true,
                "match": [{
                    "class": "Routine"
                }],
                "move": true,
                "command": ["/home/chujo/Applications/Routine.AppImage"]
            },
            "calendar": {
                "enable": true,
                "match": [
                    { "class": "chrome-calendar.google.com__calendar-Default"
                    }
                ],

                "move": true
            },
            "mail": {
                "enable": true,
                "match": [{ "class": "chrome-mail.google.com__mail_-Default" }],

                "move": true
            }
        },
        "steam": {
            "steamapp": {
                "enable": true,
                "match": [{ "title": "Steam" }],
                "move": true
            }
        },
        "on_together": {
            "game": {
                "enable": true,
                "match": [{ "initialTitle": "On-Together" }],
                "move": true
            }
        }
    },
    "wallpaper": {
        "postHook": "swww img \"$WALLPAPER_PATH\" --transition-type grow --transition-pos center --transition-duration 2 "  
    }
}
