{
    "toggles": {
        "music": {
            "spotify": {
                "enable": false
            },
            "feishin": {
                "enable": true,
                "match": [{ "class": "feishin" }],
                "move": true
            },
            "soundcloud": {
                "enable": true,
                "match": [{"class": "chrome-soundcloud.com__-Default"}],
                "move": true
            }
        },
        "google": {
            "calendar": {
                "enable": true,
                "match": [
                    { "class": "chrome-calendar.google.com__calendar-Default"
                    }
                ],

                "move": true
            },
            "mail": {
                "enable": true,
                "match": [{ "class": "chrome-mail.google.com__mail_-Default" }],

                "move": true
            }
        },
        "steam": {
            "steamapp": {
                "enable": true,
                "match": [{ "class": "steam" }],
                "move": true
            }
        }
    },
    "wallpaper": {
        "postHook": "swww img \"$WALLPAPER_PATH\" --transition-type grow --transition-pos center --transition-duration 2 "  
    }
}
